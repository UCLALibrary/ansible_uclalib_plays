# Required Settings
APP_NAME={{ avalon_app_name | default("avalon") }}
AVALON_BRANCH={{ avalon_branch | default("main") }}
SETTINGS__DOMAIN={{ avalon_url | default("http://localhost:3000/") }}
STREAMING_HOST={{ avalon_streaming_host }}
AVALON_DB_PASSWORD={{ avalon_postgresql_password }}
FEDORA_DB_PASSWORD={{ avalon_fedora_password }}
SECRET_KEY_BASE={{ avalon_secret_key_base }}

# Fedora Commons Settings
FEDORA_ADMIN_USERNAME={{ avalon_fedora_admin_username }}
FEDORA_ADMIN_PASSWORD={{ avalon_fedora_admin_password }}
AVALON_FEDORA_HOST={{ avalon_fedora_host }}

# PostgreSQL
AVALON_DB_HOST={{ avalon_db_host }}

# Solr
AVALON_SOLR_HOST={{ avalon_solr_host }}

# Recommended Settings
EMAIL_COMMENTS={{ avalon_comments_email_address }}
EMAIL_NOTIFICATION={{ avalon_notification_email_address }}
EMAIL_SUPPORT={{ avalon_support_email_address }}
SMTP_ADDRESS={{ avalon_smtp_fqdn }}
SMTP_PORT={{ avalon_smtp_port | default(587) }}

